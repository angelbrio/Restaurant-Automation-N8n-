  "name": "RestaurantWorkfow",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst input = raw.body ?? raw;\n\nconst cantidad = Number(input.cantidad || 1);\nconst plato = String(input.plato || '').toLowerCase().trim();\nconst id_comanda = input.id_comanda || `CMD-${Date.now()}`;\n\nif (plato === 'ensalada') {\n  return [\n    {\n      json: {\n        id_comanda,\n        plato: 'Ensalada',\n        cantidad,\n        ingredientes: [\n          { ingrediente: 'Lechuga', consumo: 1 * cantidad },\n          { ingrediente: 'Tomate', consumo: 2 * cantidad },\n          { ingrediente: 'Atun', consumo: 1 * cantidad }\n        ]\n      }\n    }\n  ];\n}\n\nif (plato === 'pasta con atun') {\n  return [\n    {\n      json: {\n        id_comanda,\n        plato: 'Pasta con Atun',\n        cantidad,\n        ingredientes: [\n          { ingrediente: 'Pasta', consumo: 1 * cantidad },\n          { ingrediente: 'Atun', consumo: 1 * cantidad }\n        ]\n      }\n    }\n  ];\n}\n\nthrow new Error(`Plato no soportado: ${input.plato}`);"
      },
      "type": "n8n-nodes-base.code",
